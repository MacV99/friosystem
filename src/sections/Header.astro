---
import Navbar from "../components/navbar.astro";
---

<header class="flex-row">
  <a href="/"><img src="/img/logo.jpg" alt="img-logo" /></a>

  <div class="lg-auth">
    <img
      src="/img/LG_logo.png"
      alt="LG Distribuidor Autorizado"
      class="lg-auth-logo"
    />
    <span class="lg-auth-label">Dist. Autorizado</span>
  </div>

  <!-- <Navbar /> -->
  <Navbar />
  <div class="icon-cart">
    <i class="bi bi-cart flex-row"></i>
    <span>0</span>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const iconCart = document.querySelector(".icon-cart");
    const iconCartSpan = document.querySelector(".icon-cart span");

    // Sincronizar badge con localStorage en cualquier página
    try {
      const stored = localStorage.getItem("cart");
      if (stored && iconCartSpan) {
        const cartData = JSON.parse(stored);
        const total = cartData.reduce((sum, item) => sum + item.quantity, 0);
        iconCartSpan.innerText = total;
      }
    } catch (_) {}

    iconCart?.addEventListener("click", () => {
      if (window.location.pathname === "/tienda") {
        document.body.classList.toggle("showCart");
      } else {
        window.location.href = "/tienda?cart=open";
      }
    });
  });
</script>

<style>
  /* BASE */
  header {
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 10px;
    background: var(--header-bg-mobile);
    box-shadow: var(--shadow-md);
    border-radius: 20px;
    width: 95%;
    height: 80px;
    margin: 10px auto;
    padding: 12px;
    transition: var(--transition);
    z-index: 100;
  }

  header a {
    height: 100%;
    margin-right: auto;
    display: flex;
  }

  header img {
    height: 100%;
    width: auto;
    border-radius: 8px;
    border: 1px solid var(--clr-gray);
  }

  /* ICONO CARRITO (global porque lo manipulamos con JS) */
  .icon-cart {
    background-color: var(--clr-white);
    border-radius: 12px;
    padding: 11.2px;
    cursor: pointer;
    position: relative;
    margin-left: 7px;
    border: solid 1px var(--clr-gray);
  }

  .icon-cart .bi-cart {
    font-size: 20px;
    color: var(--clr-dark);
  }

  .icon-cart span {
    position: absolute;
    color: var(--clr-white);
    background-color: var(--clr-dark);
    width: 16px;
    height: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    font-weight: 200;
    top: 4px;
    right: 4px;
    font-size: 10px;
    padding-top: 1px;
  }

  /* ── LG BADGE ── */
  header .lg-auth {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    margin-right: 20px;
    margin-left: 14px;
    opacity: 0.78;
    transition: opacity 0.2s;
  }

  header .lg-auth:hover {
    opacity: 1;
  }

  header .lg-auth-logo {
    height: 22px;
    width: auto;
    object-fit: contain;
    border: none;
    border-radius: 0;
    background: transparent;
  }

  header .lg-auth-label {
    font-size: 0.42rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--clr-dark2);
    white-space: nowrap;
  }

  /* HOVER */
  @media (hover: hover) {
    .icon-cart:hover {
      background-color: var(--clr-gray);
    }
  }

  /* RESPONSIVE */
  @media (min-width: 750px) {
    header {
      background: var(--header-bg-desktop);
      backdrop-filter: blur(5px);
      width: 98%;
    }
  }

  /* HOVER + RESPONSIVE */
  @media (hover: hover) and (min-width: 750px) {
    header:hover {
      background-color: var(--clr-white);
    }
  }
</style>
