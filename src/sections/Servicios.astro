---
import SectionHeader from "../components/SectionHeader.astro";
---

<section id="servicios">
  <SectionHeader
    eyebrow="Lo que hacemos"
    title="PORTAFOLIO DE SERVICIOS"
    description="Soluciones integrales en climatización para sectores doméstico, comercial, industrial y hospitalario"
  />

  <div class="srv-grid">
    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-tools"></i></div>
      <div class="srv-content">
        <h3>Mantenimiento</h3>
        <p>
          Mantenimiento preventivo, predictivo y correctivo de equipos de aires
          acondicionados doméstico, comercial, industrial y hospitalario en
          todas las marcas.
        </p>
      </div>
    </div>

    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-cpu"></i></div>
      <div class="srv-content">
        <h3>Automatización y Control</h3>
        <p>
          Armado de tableros de control y fuerza para todo tipo de maquinaria
          industrial. Automatización de sistemas de climatización y
          refrigeración.
        </p>
      </div>
    </div>

    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-box-seam"></i></div>
      <div class="srv-content">
        <h3>Suministro de Equipos</h3>
        <p>
          Suministro de equipos de aire acondicionado, ventilación mecánica y
          cuartos fríos de las mejores marcas a los mejores precios del mercado.
        </p>
      </div>
    </div>

    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-rulers"></i></div>
      <div class="srv-content">
        <h3>Diseño y Consultoría</h3>
        <p>
          Diseño, consultoría, montaje y reparación de equipos especiales
          Chiller, VRF y equipos de precisión con altos estándares técnicos y
          proyectos integrales.
        </p>
      </div>
    </div>

    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-wind"></i></div>
      <div class="srv-content">
        <h3>Ventilación Mecánica</h3>
        <p>
          Diseño e instalación de sistemas de ventilación mecánica para espacios
          comerciales, industriales y hospitalarios, garantizando calidad de
          aire óptima.
        </p>
      </div>
    </div>

    <div class="srv-card">
      <div class="icon-badge flex-row"><i class="bi bi-wrench-adjustable"></i></div>
      <div class="srv-content">
        <h3>Repuestos y Herramientas</h3>
        <p>
          Venta de herramientas especializadas y repuestos para equipos de
          climatización y refrigeración. Gases refrigerantes, manómetros y
          accesorios.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  #servicios {
    background-color: var(--clr-blue);
    padding: 80px 24px;
    gap: 52px;
    align-items: center;
    --sh-h2-color: #fff;
    --sh-p-color: rgba(255, 255, 255, 0.5);
  }

  /* ─── GRID ─── */
  .srv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    max-width: 980px;
    width: 100%;
  }

  .srv-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 18px;
    padding: 28px 24px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    transition: all 0.25s ease;
  }

  .srv-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  h3 {
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 2px;
  }

  .srv-card p {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ─── HOVER ─── */
  @media (hover: hover) {
    .srv-card:hover {
      background: rgba(255, 255, 255, 0.09);
      border-color: rgba(var(--rgb-red), 0.4);
      transform: translateY(-2px);
    }

    .srv-card:hover .icon-badge {
      background: var(--clr-red);
      color: #fff;
    }
  }

  /* ─── RESPONSIVE ─── */
  @media (min-width: 600px) {
    .srv-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .srv-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
