---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}
const { eyebrow, title, description } = Astro.props;
---

<div class="section-header flex-column">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  <p>{description}</p>
</div>

<style is:global>
  .section-header {
    gap: 14px;
    max-width: 640px;
    text-align: center;
  }

  .section-header h2 {
    font-size: 1.6rem;
    letter-spacing: 4px;
    line-height: 1.2;
    color: var(--sh-h2-color, var(--clr-blue));
  }

  .section-header p {
    font-size: 0.85rem;
    letter-spacing: 0.3px;
    color: var(--sh-p-color, var(--clr-dark2));
  }

  @media (min-width: 750px) {
    .section-header h2 {
      font-size: 2rem;
    }
  }
</style>
