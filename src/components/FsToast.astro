---
interface Props {
  toastId: string;
}
const { toastId } = Astro.props;
---

<div id={toastId} class="fs-toast flex-row">
  <span id={`${toastId}-icon`} class="fs-toast-icon"></span>
  <span id={`${toastId}-msg`}></span>
</div>

<style is:global>
  .fs-toast {
    position: fixed;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%) translateY(16px);
    background: var(--fs-toast-bg, #1e293b);
    color: var(--fs-toast-color, #f8fafc);
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    gap: 8px;
    z-index: 10000;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      transform 0.32s cubic-bezier(0.34, 1.4, 0.64, 1),
      visibility 0.25s ease;
    white-space: nowrap;
    pointer-events: none;
    max-width: none;
    width: auto;
  }

  .fs-toast.fs-toast-visible {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .fs-toast-icon {
    font-size: 15px;
    line-height: 1;
  }
</style>
