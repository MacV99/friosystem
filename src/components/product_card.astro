---
// Plantilla reutilizable para tarjetas de producto. Clonada por JS en Shop.astro
---

<template id="product-card-tpl">
  <div class="product-card" data-id="">
    <div class="item-img-wrap">
      <img src="" alt="" loading="lazy" />
      <span class="item-badge">OFERTA</span>
    </div>
    <div class="item-body">
      <p class="product-name"></p>
      <div class="item-prices">
        <span class="original-price"></span>
        <strong class="price"></strong>
      </div>
      <button class="addCart button1">
        <i class="bi bi-cart-plus"></i> Agregar
      </button>
    </div>
  </div>
</template>

<style is:inline>
  /* ── TARJETA ── */
  .product-card {
    background: #ffffff;
    border-radius: 18px;
    border: 1px solid var(--clr-gray);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: var(--shadow-sm);
    width: 100%;
    animation: fadeInUp 0.45s ease both;
  }

  /* ── IMAGEN ── */
  .item-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .product-card img {
    width: 100%;
    height: 190px;
    object-fit: contain;
    padding: 18px;
    transition: transform 0.35s ease;
    display: block;
  }

  /* ── BADGE OFERTA ── */
  .item-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--clr-accent);
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 4px 10px;
    border-radius: 50px;
    text-transform: uppercase;
    pointer-events: none;
  }

  /* ── CUERPO ── */
  .item-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .product-card .product-name {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--clr-dark2);
    line-height: 1.5;
    margin: 0;
  }

  /* ── PRECIOS ── */
  .item-prices {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: auto;
  }
  .product-card .original-price {
    font-size: 10px;
    color: #bbb;
    text-decoration: line-through;
    font-weight: 400;
    letter-spacing: 0;
  }
  .product-card .price {
    font-size: 15px;
    font-weight: 800;
    color: var(--clr-primary);
    letter-spacing: 0.5px;
    text-transform: none;
  }
  .product-card .price.price-consultar {
    font-size: 11px;
    font-weight: 700;
    color: var(--clr-dark2);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ── BOTÓN ── */
  .product-card .addCart {
    width: 100%;
    justify-content: center;
    font-size: 11px;
    border-radius: 12px;
    padding: 9px 14px;
    gap: 7px;
    letter-spacing: 1.5px;
  }

  .button1 {
    background-color: var(--clr-primary);
  }

  /* ── HOVER ── */
  @media (hover: hover) {
    .product-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-4px);
    }
    .product-card:hover .item-img-wrap img {
      transform: scale(1.04);
    }
    .product-card .addCart:hover {
      background-color: var(--clr-primary-mid);
    }
  }
</style>
