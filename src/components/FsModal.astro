---
interface Props {
  modalId: string;
}
const { modalId } = Astro.props;
---

<div id={modalId} class="fs-modal-backdrop flex-row">
  <div class="fs-modal-card">
    <button
      id={`${modalId}-close`}
      class="fs-modal-close flex-row"
      aria-label="Cerrar"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="fs-modal-icon-wrap flex-row">
      <div id={`${modalId}-icon`} class="fs-modal-icon flex-row"></div>
    </div>

    <div class="fs-modal-header">
      <span id={`${modalId}-title`} class="fs-modal-title">Aviso</span>
    </div>

    <div id={`${modalId}-body`} class="fs-modal-body"></div>

    <div class="fs-modal-footer flex-row">
      <button id={`${modalId}-ok`} class="fs-modal-btn">Entendido</button>
    </div>
  </div>
</div>

<style is:global>
  /* ── BACKDROP ── */
  .fs-modal-backdrop {
    position: fixed;
    inset: 0;
    background: var(--modal-backdrop);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 9999;
    padding: 16px;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      visibility 0.25s ease;
    max-width: none;
    width: 100%;
  }

  .fs-modal-backdrop.fs-modal-visible {
    opacity: 1;
    visibility: visible;
  }

  /* ── CARD ── */
  .fs-modal-card {
    position: relative;
    width: min(460px, 95vw);
    max-height: 88vh;
    background-color: var(--clr-white);
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    transform: translateY(20px) scale(0.97);
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.25s ease;
    opacity: 0;
    display: flex;
    flex-direction: column;
  }

  .fs-modal-backdrop.fs-modal-visible .fs-modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .fs-modal-card.fs-modal-data {
    width: min(650px, 95vw);
  }

  /* ── BOTÓN CERRAR ── */
  .fs-modal-card .fs-modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.06);
    color: var(--clr-dark2);
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    min-width: unset;
    max-width: unset;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: none;
    transform: none;
    padding: 0;
    flex-shrink: 0;
  }

  /* ── ÍCONO ── */
  .fs-modal-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 0 6px;
    flex-shrink: 0;
  }

  .fs-modal-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    font-size: 22px;
    line-height: 1;
  }

  .fs-icon-aviso { background: var(--clr-modal-aviso); }
  .fs-icon-error { background: var(--clr-modal-error); }
  .fs-icon-exito { background: var(--clr-modal-exito); }
  .fs-icon-carga { background: var(--clr-modal-carga); }

  /* ── HEADER ── */
  .fs-modal-header {
    flex-shrink: 0;
    padding: 0 24px;
  }

  .fs-modal-title {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: var(--clr-dark);
    text-align: center;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── BODY — único elemento que hace scroll ── */
  .fs-modal-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 16px;
    color: var(--clr-dark2);
    font-size: 13px;
    line-height: 1.5;
    text-align: center;
  }

  /* ── FOOTER ── */
  .fs-modal-footer {
    flex-shrink: 0;
    padding: 12px 24px 20px;
  }

  .fs-modal-card .fs-modal-btn {
    background-color: var(--clr-blue);
    color: var(--clr-white);
    border: none;
    border-radius: 10px;
    padding: 11px 40px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
    width: auto;
    max-width: unset;
  }

  /* ── HOVER ── */
  @media (hover: hover) {
    .fs-modal-card .fs-modal-close:hover {
      background: rgba(0, 0, 0, 0.14);
    }

    .fs-modal-card .fs-modal-btn:hover {
      opacity: 0.88;
      transform: translateY(-1px);
    }
  }

  /* ── RESPONSIVE ── */
  @media (min-width: 750px) {
    .fs-modal-body {
      padding: 5px 24px 8px;
    }
  }
</style>
