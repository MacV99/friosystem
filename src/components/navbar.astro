<nav class="flex-column" aria-label="Menú principal">
  <i class="bi bi-list open-nav" aria-label="Abrir menú"></i>

  <div class="flex-column" id="overlay">
    <a href="/">Inicio</a>
    <a href="/reporte">Reporte</a>
    <!-- 🔧 FIX: "clientes" → "Clientes" (consistencia visual) -->
    <a href="/clientes">Clientes</a>
    <i class="bi bi-x-lg close-nav" aria-label="Cerrar menú"></i>
  </div>
</nav>

<style>
  /* BASE */
  .open-nav {
    font-size: 20px;
    cursor: pointer;
    background-color: var(--clr-white);
    border: solid 1px var(--clr-gray);
    border-radius: 12px;
    padding: 11.2px;
  }

  #overlay {
    display: none;
    position: fixed;
    inset: 0;
    gap: 7%;
    background: var(--clr-white);
    z-index: 100;
  }

  #overlay.new-nav {
    display: flex;
  }

  .close-nav {
    position: absolute;
    top: 0;
    right: 0;
    margin: 28px;
    font-size: 24px;
    cursor: pointer;
    border-radius: 10px;
    padding: 7px;
    background: var(--clr-white);
    color: var(--clr-dark);
    border: solid 1px var(--clr-gray);
  }

  #overlay a {
    font-size: 15px;
    font-weight: 600;
    background: var(--clr-white);
    padding: 12px 20px;
    border: solid 1px var(--clr-gray);
    border-radius: 12px;
    letter-spacing: 5px;
    width: 210px;
    text-align: center;
    text-transform: uppercase;
    color: var(--clr-dark);
    transition: var(--transition);
  }

  /* HOVER */
  @media (hover: hover) {
    #overlay a:hover {
      background-color: var(--clr-blue);
      color: var(--clr-white);
      border-color: var(--clr-blue);
    }
  }

  /* RESPONSIVE */
  @media (min-width: 750px) {
    .open-nav,
    .close-nav {
      display: none;
    }

    #overlay {
      display: flex;
      position: relative;
      inset: auto;
      flex-direction: row;
      width: auto;
      height: auto;
      gap: 7px;
      background: transparent;
    }

    #overlay a {
      font-size: 12px;
      letter-spacing: 2px;
      width: auto;
      padding: 8px 14px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("overlay");
    const openBtn = document.querySelector(".open-nav");
    const closeBtn = document.querySelector(".close-nav");

    const open = () => {
      if (overlay) overlay.style.display = "flex";
    };
    const close = () => {
      if (overlay) overlay.style.display = "none";
    };

    openBtn?.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });

    // Marcar link activo
    const currentPath = window.location.pathname;
    overlay?.querySelectorAll("a").forEach((link) => {
      if (link.getAttribute("href") === currentPath) {
        link.style.backgroundColor = "var(--clr-blue)";
        link.style.color = "#fff";
        link.style.borderColor = "var(--clr-blue)";
      }
    });
  });
</script>
