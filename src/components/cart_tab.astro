---
// Carrito lateral — HTML + CSS (handlers en Shop.astro para acceder al estado)
---

<div class="cartTab flex-column">
  <div class="cart-header flex-row">
    <i class="bi bi-cart3"></i>
    <h2>Tu Carrito</h2>
  </div>
  <div class="listCart flex-column"></div>
  <div class="cart-actions">
    <button class="close cart-btn-close">
      <i class="bi bi-x-lg"></i> Cerrar
    </button>
    <button class="clean cart-btn-clean">
      <i class="bi bi-trash3"></i> Limpiar
    </button>
    <button class="buy cart-btn-buy">
      <i class="bi bi-whatsapp"></i> Realizar pedido
    </button>
  </div>
</div>

<style is:inline>
  /* ── PANEL ── */
  .cartTab {
    width: 380px;
    background-color: #fff;
    position: fixed;
    top: 0;
    right: -420px;
    bottom: 0;
    transition: right 0.3s ease;
    border-left: 1px solid var(--clr-gray);
    box-shadow: -4px 0 24px rgba(var(--rgb-primary), 0.12);
    z-index: 111;
    justify-content: flex-start;
  }
  .showCart .cartTab {
    right: 0;
  }
  .showCart .whatsapp-float {
    display: none;
  }

  /* ── HEADER ── */
  .cart-header {
    background: var(--clr-primary);
    color: #fff;
    padding: 18px 20px;
    width: 100%;
    gap: 10px;
    justify-content: flex-start;
    flex-shrink: 0;
  }
  .cart-header i {
    font-size: 20px;
    color: #fff;
  }
  .cart-header h2 {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 4px;
    color: #fff;
    text-transform: uppercase;
  }

  /* ── LISTA ── */
  .cartTab .listCart {
    flex: 1;
    overflow-y: auto;
    width: 100%;
    justify-content: flex-start;
    gap: 0;
    padding-bottom: 8px;
  }
  .cartTab .listCart::-webkit-scrollbar {
    width: 4px;
  }
  .cartTab .listCart::-webkit-scrollbar-thumb {
    background: var(--clr-gray);
    border-radius: 4px;
  }

  /* ── ITEMS ── */
  .cartTab .listCart .item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0;
    width: 100%;
    padding: 10px 16px;
    border-bottom: 1px solid var(--clr-gray);
    font-size: 11px;
    background: #fff;
    transition: background 0.15s;
    border-radius: 0;
  }
  .cartTab .listCart .item:nth-child(even) {
    background: var(--cart-item-odd);
  }
  .cartTab .listCart .item div.image {
    width: 50px;
    height: 50px;
    min-width: 50px;
    border-radius: 10px;
    overflow: hidden;
    background: var(--clr-primary-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 10px;
  }
  .cartTab .listCart .item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }
  .cartTab .listCart .item .name {
    flex: 1;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--clr-dark);
    line-height: 1.4;
    padding-right: 6px;
  }
  .cartTab .listCart .item .totalPrice {
    font-size: 11px;
    font-weight: 700;
    color: var(--clr-primary);
    min-width: 72px;
    text-align: right;
    margin-right: 8px;
  }

  /* ── CONTROLES DE CANTIDAD ── */
  .cartTab .listCart .quantity {
    display: flex;
    align-items: center;
    gap: 0;
    border-radius: 10px;
    border: 1px solid var(--clr-gray);
    overflow: hidden;
    background: var(--clr-white);
  }
  .cartTab .listCart .quantity span {
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    color: var(--clr-dark);
    transition: background 0.15s;
  }
  .cartTab .listCart .quantity span:nth-child(2) {
    font-size: 11px;
    font-weight: 700;
    cursor: default;
    width: 22px;
    border-left: 1px solid var(--clr-gray);
    border-right: 1px solid var(--clr-gray);
    color: var(--clr-primary);
  }
  .cartTab .listCart .quantity span .bi {
    font-size: 13px;
    color: var(--clr-dark2);
  }
  @media (hover: hover) {
    .cartTab .listCart .quantity span:first-child:hover,
    .cartTab .listCart .quantity span:last-child:hover {
      background: var(--clr-primary);
    }
    .cartTab .listCart .quantity span:first-child:hover .bi,
    .cartTab .listCart .quantity span:last-child:hover .bi {
      color: #fff;
    }
  }

  /* ── TOTAL ── */
  .cartTab .cart-total {
    padding: 12px 16px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--clr-primary);
    text-align: right;
    border-top: 2px solid var(--clr-primary-light);
    background: #fff;
  }

  /* ── ACCIONES ── */
  .cart-actions {
    display: flex;
    width: 100%;
    flex-shrink: 0;
    border-top: 1px solid var(--clr-gray);
  }
  .cart-actions button {
    flex: 1;
    padding: 14px 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    transition: var(--transition);
  }
  .cart-actions button i {
    font-size: 18px;
  }
  .cart-btn-close {
    background: var(--clr-white);
    color: var(--clr-dark2);
    border-right: 1px solid var(--clr-gray);
  }
  .cart-btn-clean {
    background: var(--clr-white);
    color: var(--clr-danger);
    border-right: 1px solid var(--clr-gray);
  }
  .cart-btn-buy {
    background: var(--clr-accent);
    color: #fff;
  }
  @media (hover: hover) {
    .cart-btn-close:hover {
      background: var(--clr-gray);
    }
    .cart-btn-clean:hover {
      background: #fee2e2;
    }
    .cart-btn-buy:hover {
      background: var(--clr-accent2);
    }
  }
</style>

<script is:inline>
  const closeCart = document.querySelector(".cart-btn-close");
  const $cleanCart = document.querySelector(".cart-btn-clean");
  const $btnBuy = document.querySelector(".cart-btn-buy");

  closeCart?.addEventListener("click", () => body.classList.toggle("showCart"));

  $cleanCart?.addEventListener("click", () => {
    cart = [];
    addCartToHTML();
    localStorage.removeItem("cart");
  });

  $btnBuy?.addEventListener("click", () => {
    if (!cart.length) return;
    const totalEl = document.querySelector(".cart-total strong");
    const total = totalEl ? totalEl.innerText : "Total: $0";
    let mensaje = `Hola AC FRIOSYSTEM!, quiero hacer un pedido:\n\n`;
    cart.forEach((item) => {
      const p = products[item.product_id];
      const pStr = p.price > 0 ? `$${p.price.toLocaleString("es-CO")}` : "Consultar precio";
      const tStr = p.price > 0 ? `$${(p.price * item.quantity).toLocaleString("es-CO")}` : "Consultar precio";
      mensaje += `- ${p.name} - ${pStr} x ${item.quantity} = ${tStr}\n`;
    });
    mensaje += `\n*${total}*`;
    window.open(
      `https://wa.me/573222887148?text=${encodeURIComponent(mensaje)}`,
      "_blank",
    );
  });
</script>
