---
// Sin imports
---

<section id="consulta-equipos" class="flex-column">
  <div class="flex-column recuadro">
    <h2>Consulta el Estado de tus Equipos</h2>
    <p>
      Ingresa tu número de identificación para ver el estado actual de tus
      equipos con nosotros
    </p>

    <div class="form-container flex-column">
      <input
        type="text"
        id="identificacion"
        placeholder="Ingresa tu Cédula o NIT"
      />
      <button onclick="consultarEstado()">Consultar</button>
    </div>
  </div>

  <!-- ── MODAL ── -->
  <div id="fs-modal" class="fs-modal-backdrop">
    <div class="fs-modal-card">
      <button id="fs-modal-close" class="fs-modal-close" aria-label="Cerrar">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="fs-modal-icon-wrap">
        <div id="fs-modal-icon" class="fs-modal-icon"></div>
      </div>

      <div class="fs-modal-header">
        <span id="fs-modal-title">Aviso</span>
      </div>

      <div id="fs-modal-body" class="fs-modal-body">
        <!-- Contenido dinámico -->
      </div>

      <div class="fs-modal-footer">
        <button id="fs-modal-ok" class="fs-modal-btn">Entendido</button>
      </div>
    </div>
  </div>

  <!-- ── TOAST ── -->
  <div id="fs-toast" class="fs-toast">
    <span id="fs-toast-icon" class="fs-toast-icon"></span>
    <span id="fs-toast-msg"></span>
  </div>
</section>

<style is:inline>
  /* BASE */

  /* ── FORMULARIO ── */
  #consulta-equipos {
    gap: 10px;
    background-color: var(--clr-white);
  }

  .recuadro {
    background-color: var(--clr-white);
    padding: 32px 24px;
    border-radius: 20px;
    border: 1px solid var(--clr-gray);
    width: 100%;
    max-width: 560px;
    text-align: center;
    box-shadow: var(--shadow-md);
  }

  #consulta-equipos h2 {
    color: var(--clr-blue);
    margin-bottom: 8px;
    text-align: center;
  }

  #consulta-equipos p {
    color: var(--clr-dark2);
    margin-bottom: 22px;
  }

  .form-container {
    gap: 10px;
    width: 100%;
  }

  #consulta-equipos input {
    width: 100%;
    max-width: 400px;
    padding: 12px 16px;
    font-size: 15px;
    border-radius: 12px;
    border: 1.5px solid var(--clr-gray);
    background-color: var(--clr-white);
    transition: var(--transition);
  }

  #consulta-equipos input:focus {
    outline: none;
    border-color: var(--clr-blue);
    box-shadow: 0 0 0 3px rgba(3, 33, 50, 0.08);
  }

  /* Solo el botón del formulario, no los botones del modal */
  .form-container button {
    background-color: var(--clr-blue);
    color: var(--clr-white);
    border: none;
    border-radius: 12px;
    padding: 12px 36px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
    width: 100%;
    max-width: 400px;
  }

  /* ── MODAL BACKDROP ── */
  .fs-modal-backdrop {
    position: fixed;
    inset: 0;
    background: var(--modal-backdrop);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 16px;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      visibility 0.25s ease;
    max-width: none;
    width: 100%;
  }

  .fs-modal-backdrop.fs-modal-visible {
    opacity: 1;
    visibility: visible;
  }

  /* ── MODAL CARD — flex column: header fijo, body scrollea, footer fijo ── */
  .fs-modal-card {
    position: relative;
    width: min(420px, 92vw); /* mensajes simples: aviso, error, carga */
    max-height: 88vh;
    background-color: var(--clr-white);
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    transform: translateY(20px) scale(0.97);
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.25s ease;
    opacity: 0;
    display: flex;
    flex-direction: column;
  }

  .fs-modal-backdrop.fs-modal-visible .fs-modal-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* Modal amplio para resultados con datos de cliente */
  .fs-modal-card.fs-modal-data {
    width: min(730px, 95vw);
  }

  /* ── BOTÓN CERRAR ── */
  .fs-modal-card .fs-modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(0, 0, 0, 0.06);
    color: var(--clr-dark2);
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    min-width: unset;
    max-width: unset;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    box-shadow: none;
    transform: none;
    letter-spacing: 0;
    padding: 0;
    flex-shrink: 0;
  }

  /* ── ÍCONO MODAL ── */
  .fs-modal-icon-wrap {
    display: flex;
    justify-content: center;
    padding: 24px 0 6px;
    flex-shrink: 0;
  }

  .fs-modal-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .fs-icon-aviso {
    background: var(--clr-modal-aviso);
  }
  .fs-icon-error {
    background: var(--clr-modal-error);
  }
  .fs-icon-exito {
    background: var(--clr-modal-exito);
  }
  .fs-icon-carga {
    background: var(--clr-modal-carga);
  }

  /* ── HEADER MODAL ── */
  .fs-modal-header {
    flex-shrink: 0;
    padding: 4px 48px 14px;
  }

  #fs-modal-title {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: var(--clr-dark);
    text-align: center;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── BODY MODAL — único elemento que hace scroll ── */
  .fs-modal-body {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 16px;
    color: var(--clr-dark2);
    font-size: 13px;
    line-height: 1.5;
    text-align: center; /* mensajes simples centrados */
  }

  /* Las secciones de datos sí van a la izquierda */
  .fs-modal-body .seccion {
    text-align: left;
  }

  .info-label,
  .info-value {
    text-align: left;
  }

  /* ── SECCIONES ── */
  .seccion {
    margin-bottom: 14px;
  }

  .seccion-titulo {
    display: inline-block;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--clr-blue-mid);
    background-color: var(--clr-blue-light);
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 8px;
  }

  .seccion-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 6px;
  }

  /* ── INFO CARD ── */
  .info-card {
    background-color: var(--clr-white);
    padding: 8px 12px;
    border-radius: 10px;
    border: 1px solid var(--clr-gray);
  }

  .info-card.full-width {
    grid-column: 1 / -1;
  }

  .info-label {
    display: block;
    font-size: 9px;
    font-weight: 800;
    color: var(--clr-blue-mid);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 2px;
  }

  .info-value {
    display: block;
    font-size: 13px;
    color: var(--clr-dark);
    font-weight: 600;
    line-height: 1.4;
  }

  /* ── ACORDEÓN ── */
  .registro {
    border: 1px solid var(--clr-gray);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .registro-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background-color: var(--clr-blue);
    color: var(--clr-white);
    padding: 10px 14px;
    cursor: pointer;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition);
    margin-bottom: 0;
  }

  .registro-chevron {
    font-size: 9px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .registro-body {
    display: none;
    padding: 12px;
    background-color: var(--clr-white);
  }

  .registro-body.abierto {
    display: block;
  }

  /* ── FOTO ── */
  .foto-registro {
    display: block;
    width: 100%;
    max-height: 350px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--clr-gray);
    margin-top: 4px;
  }

  .foto-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 72px;
    background-color: var(--clr-blue-light);
    border: 1px dashed var(--clr-gray);
    border-radius: 10px;
    margin-top: 4px;
    font-size: 12px;
    font-weight: 600;
    color: var(--clr-dark2);
    letter-spacing: 1px;
  }

  /* ── FOOTER MODAL ── */
  .fs-modal-footer {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    padding: 12px 24px 20px;
  }

  .fs-modal-card .fs-modal-btn {
    background-color: var(--clr-blue);
    color: var(--clr-white);
    border: none;
    border-radius: 10px;
    padding: 11px 40px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition);
    width: auto;
    max-width: unset;
  }

  /* ── TOAST ── */
  .fs-toast {
    position: fixed;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%) translateY(16px);
    background: var(--clr-blue);
    color: var(--clr-white);
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 10000;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      transform 0.32s cubic-bezier(0.34, 1.4, 0.64, 1),
      visibility 0.25s ease;
    white-space: nowrap;
    pointer-events: none;
    max-width: none;
    width: auto;
  }

  .fs-toast.fs-toast-visible {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .fs-toast-icon {
    font-size: 15px;
    line-height: 1;
  }

  /* HOVER */
  @media (hover: hover) {
    .form-container button:hover {
      opacity: 0.88;
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }

    .registro-header:hover {
      background-color: var(--clr-blue-mid);
    }

    .fs-modal-card .fs-modal-close:hover {
      background: rgba(0, 0, 0, 0.14);
    }

    .fs-modal-card .fs-modal-btn:hover {
      opacity: 0.88;
      transform: translateY(-1px);
    }
  }

  /* RESPONSIVE */
  @media (min-width: 750px) {
    .fs-modal-body {
      padding: 16px 24px 8px;
    }

    .registro-body {
      padding: 14px 16px;
    }

    .seccion-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>

<script is:inline>
  //@ts-nocheck

  const SHEET_URL =
    "https://docs.google.com/spreadsheets/d/e/2PACX-1vQW9HE0pnzSsXfqoD9qXe28EMfT2D6AFhoM3T_83Z8ajhdKDgL86tE8cSRfTTTtuVVm8j1KZLrHefc_/pub?gid=0&single=true&output=csv";

  /* ── TOAST ── */
  let toastTimer;
  function fsToast(msg, icono = "🔔") {
    clearTimeout(toastTimer);
    const t = document.getElementById("fs-toast");
    document.getElementById("fs-toast-icon").textContent = icono;
    document.getElementById("fs-toast-msg").textContent = msg;
    t.classList.add("fs-toast-visible");
    toastTimer = setTimeout(() => t.classList.remove("fs-toast-visible"), 3200);
  }

  /* ── MODAL ── */
  const VARIANTES = {
    aviso: { emoji: "💡", clase: "fs-icon-aviso" },
    error: { emoji: "❌", clase: "fs-icon-error" },
    exito: { emoji: "✅", clase: "fs-icon-exito" },
    carga: { emoji: "❄️", clase: "fs-icon-carga" },
  };

  function fsModalShow({ title, body, variante = "aviso" }) {
    const v = VARIANTES[variante] || VARIANTES.aviso;
    const iconEl = document.getElementById("fs-modal-icon");
    iconEl.textContent = v.emoji;
    iconEl.className = "fs-modal-icon " + v.clase;
    document.getElementById("fs-modal-title").textContent = title;
    document.getElementById("fs-modal-body").innerHTML = body;
    // Ancho amplio solo cuando hay datos de cliente (variante exito)
    document.querySelector(".fs-modal-card").classList.toggle("fs-modal-data", variante === "exito");
    document.getElementById("fs-modal").classList.add("fs-modal-visible");
  }

  function fsModalHide() {
    document.getElementById("fs-modal").classList.remove("fs-modal-visible");
    document.getElementById("fs-modal-body").innerHTML = "";
    document.getElementById("identificacion").value = "";
  }

  document.getElementById("fs-modal-ok").onclick = fsModalHide;
  document.getElementById("fs-modal-close").onclick = fsModalHide;
  document.getElementById("fs-modal").addEventListener("click", function (e) {
    if (e.target === this) fsModalHide();
  });

  /* ── CSV PARSER (maneja campos con comas entre comillas) ── */
  function parseCsvLine(line) {
    const result = [];
    let cur = "",
      inQuote = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"') {
        inQuote = !inQuote;
      } else if (ch === "," && !inQuote) {
        result.push(cur.trim());
        cur = "";
      } else {
        cur += ch;
      }
    }
    result.push(cur.trim());
    return result;
  }

  /* ── BUSCAR COLUMNA POR PALABRAS CLAVE ── */
  function findCol(headers, ...keywords) {
    return headers.findIndex((h) => keywords.some((kw) => h.includes(kw)));
  }

  /* ── HELPER: genera una tarjeta de dato ── */
  function campo(label, value, fullWidth = false) {
    if (!value) return "";
    return `
      <div class="info-card${fullWidth ? " full-width" : ""}">
        <span class="info-label">${label}</span>
        <span class="info-value">${value}</span>
      </div>`;
  }

  /* ── CONSTRUYE EL HTML DE UN REGISTRO ── */
  function buildRegistroHTML(d, index, total) {
    const esMultiple = total > 1;
    const bodyId = `registro-body-${index}`;

    const medElec = d.l1 || d.l2 || d.l3 || d.voltaje;
    const presTemp = d.succion || d.desc_p || d.tSum || d.tRet || d.tAmb;
    const funcionario = d.funcionario || d.telefono;

    const secciones = `
      <div class="seccion">
        <div class="seccion-titulo">Cliente</div>
        <div class="seccion-grid">
          ${campo("Cédula / NIT", d.cedula)}
          ${campo("Cliente", d.cliente)}
          ${campo("Ciudad", d.ciudad)}
          ${campo("Zona de Servicio", d.zona)}
        </div>
      </div>

      <div class="seccion">
        <div class="seccion-titulo">Equipo</div>
        <div class="seccion-grid">
          ${campo("Tipo de Equipo", d.tipoEquipo)}
          ${campo("Marca", d.marca)}
          ${campo("N° Inventario", d.inventario)}
          ${campo("Tipo Servicio", d.tipoServicio)}
          ${campo("Capacidad", d.capacidad)}
        </div>
      </div>

      ${
        medElec
          ? `
      <div class="seccion">
        <div class="seccion-titulo">Mediciones eléctricas</div>
        <div class="seccion-grid">
          ${campo("L1 (amp)", d.l1)}
          ${campo("L2 (amp)", d.l2)}
          ${campo("L3 (amp)", d.l3)}
          ${campo("Voltaje", d.voltaje)}
        </div>
      </div>`
          : ""
      }

      ${
        presTemp
          ? `
      <div class="seccion">
        <div class="seccion-titulo">Presiones y temperaturas</div>
        <div class="seccion-grid">
          ${campo("P. Succión", d.succion)}
          ${campo("P. Desc", d.desc_p)}
          ${campo("T. Sum", d.tSum)}
          ${campo("T. Ret", d.tRet)}
          ${campo("T. Amb", d.tAmb)}
        </div>
      </div>`
          : ""
      }

      <div class="seccion">
        <div class="seccion-titulo">Servicio</div>
        <div class="seccion-grid">
          ${campo("Descripción", d.descripcion, true)}
          ${campo("Material Utilizado", d.material)}
          ${campo("Técnico", d.tecnico)}
          ${campo("Calificación", d.calificacion)}
          ${campo("Observación", d.observacion, true)}
        </div>
      </div>

      ${
        funcionario
          ? `
      <div class="seccion">
        <div class="seccion-titulo">Funcionario</div>
        <div class="seccion-grid">
          ${campo("Nombre", d.funcionario)}
          ${campo("Teléfono", d.telefono)}
        </div>
      </div>`
          : ""
      }

      ${
        d.foto
          ? `
      <div class="seccion">
        <div class="seccion-titulo">Registro fotográfico</div>
        <img src="${d.foto}" class="foto-registro" alt="Registro fotográfico" loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="foto-placeholder" style="display:none">📷 Sin imagen disponible</div>
      </div>`
          : `
      <div class="seccion">
        <div class="seccion-titulo">Registro fotográfico</div>
        <div class="foto-placeholder">📷 Sin registro fotográfico</div>
      </div>`
      }
    `;

    if (!esMultiple) return secciones;

    const etiqueta =
      [d.marca, d.tipoServicio].filter(Boolean).join(" | ") ||
      `Servicio ${index + 1}`;
    return `
      <div class="registro">
        <div class="registro-header" data-target="${bodyId}">
          <span>Servicio ${index + 1} — ${etiqueta}</span>
          <span class="registro-chevron">${index === 0 ? "▲" : "▼"}</span>
        </div>
        <div class="registro-body${index === 0 ? " abierto" : ""}" id="${bodyId}">
          ${secciones}
        </div>
      </div>`;
  }

  /* ── INICIALIZAR ACORDEÓN ── */
  function initAcordeon() {
    document.querySelectorAll(".registro-header").forEach((header) => {
      header.addEventListener("click", () => {
        const bodyId = header.getAttribute("data-target");
        const body = document.getElementById(bodyId);
        const chevron = header.querySelector(".registro-chevron");
        const isOpen = body.classList.contains("abierto");
        body.classList.toggle("abierto", !isOpen);
        if (chevron) chevron.textContent = !isOpen ? "▲" : "▼";
      });
    });
  }

  /* ── LÓGICA DE BÚSQUEDA ── */
  async function buscarDatos(identificacion, url) {
    const res = await fetch(`${url}&rand=${Date.now()}`, {
      cache: "no-store",
      mode: "cors",
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const csv = await res.text();
    const lines = csv.trim().split("\n");
    if (lines.length < 2) return null;

    const headers = parseCsvLine(lines[0]).map((h) =>
      h.toLowerCase().replace(/['"]/g, ""),
    );

    const iCedula = findCol(
      headers,
      "cedula",
      "nit",
      "identificacion",
      "cédula",
    );
    const iCliente = findCol(headers, "cliente");
    const iZona = findCol(headers, "zona");
    const iCiudad = findCol(headers, "ciudad");
    const iTipoEquipo = findCol(headers, "tipo de equipo", "tipo equipo");
    const iMarca = findCol(headers, "marca");
    const iInventario = findCol(headers, "inventario");
    const iTipoSvc = findCol(headers, "tipo servicio");
    const iCapacidad = findCol(headers, "capacidad");
    const iL1 = findCol(headers, "l1");
    const iL2 = findCol(headers, "l2");
    const iL3 = findCol(headers, "l3");
    const iSuccion = findCol(headers, "succion", "succión");
    const iDescP = findCol(headers, "p. desc");
    const iVoltaje = findCol(headers, "voltaje");
    const iTSum = findCol(headers, "t. sum");
    const iTRet = findCol(headers, "t. ret");
    const iTAmb = findCol(headers, "t. amb");
    const iDescripcion = findCol(headers, "descripcion", "descripción");
    const iMaterial = findCol(headers, "material");
    const iFuncionario = findCol(headers, "nombre funcionario");
    const iTelefono = findCol(headers, "telefono", "teléfono");
    const iFoto = findCol(headers, "fotografico", "fotográfico");
    const iCalif = findCol(headers, "calificacion", "calificación");
    const iTecnico = findCol(headers, "tecnico", "técnico");
    const iObservacion = findCol(headers, "observacion", "observación");

    if (iCedula === -1) {
      fsModalShow({
        title: "Error de configuración",
        body: `No se encontró la columna de cédula/NIT.<br><small>Columnas detectadas: ${headers.join(", ")}</small>`,
        variante: "error",
      });
      return null;
    }

    const id = identificacion.trim().toLowerCase();
    const filas = [];

    for (let i = 1; i < lines.length; i++) {
      if (!lines[i].trim()) continue;
      const cells = parseCsvLine(lines[i]);
      if (cells[iCedula]?.toLowerCase().trim() === id) {
        filas.push({
          cedula: cells[iCedula] || "",
          cliente: cells[iCliente] || "",
          zona: cells[iZona] || "",
          ciudad: cells[iCiudad] || "",
          tipoEquipo: cells[iTipoEquipo] || "",
          marca: cells[iMarca] || "",
          inventario: cells[iInventario] || "",
          tipoServicio: cells[iTipoSvc] || "",
          capacidad: cells[iCapacidad] || "",
          l1: cells[iL1] || "",
          l2: cells[iL2] || "",
          l3: cells[iL3] || "",
          succion: cells[iSuccion] || "",
          desc_p: cells[iDescP] || "",
          voltaje: cells[iVoltaje] || "",
          tSum: cells[iTSum] || "",
          tRet: cells[iTRet] || "",
          tAmb: cells[iTAmb] || "",
          descripcion: cells[iDescripcion] || "",
          material: cells[iMaterial] || "",
          funcionario: cells[iFuncionario] || "",
          telefono: cells[iTelefono] || "",
          foto: cells[iFoto] || "",
          calificacion: cells[iCalif] || "",
          tecnico: cells[iTecnico] || "",
          observacion: cells[iObservacion] || "",
        });
      }
    }

    return filas.length ? filas : null;
  }

  async function buscarConReintentos(identificacion, url, intentos = 3) {
    for (let i = 0; i < intentos; i++) {
      try {
        const datos = await buscarDatos(identificacion, url);
        if (datos) return datos;
      } catch (e) {
        console.warn(`Intento ${i + 1} fallido:`, e);
      }
      await new Promise((r) => setTimeout(r, 800));
    }
    return null;
  }

  async function consultarEstado() {
    const identificacion = document
      .getElementById("identificacion")
      .value.trim();

    if (!identificacion) {
      fsModalShow({
        title: "Campo vacío",
        body: "Por favor ingresa tu número de cédula o NIT para consultar.",
        variante: "aviso",
      });
      return;
    }

    fsToast("Consultando tu información...", "🔍");

    const registros = await buscarConReintentos(identificacion, SHEET_URL);

    if (!registros) {
      fsToast("No se encontró el registro", "❌");
      setTimeout(() => {
        fsModalShow({
          title: "Sin resultados",
          body: "No encontramos información asociada a esta identificación.<br>Verifica el número ingresado o contáctanos.",
          variante: "error",
        });
      }, 600);
      return;
    }

    const nombre = registros[0].cliente || identificacion;
    const body = registros
      .map((r, i) => buildRegistroHTML(r, i, registros.length))
      .join("");

    fsToast("¡Registro encontrado!", "✅");
    setTimeout(() => {
      fsModalShow({
        title:
          registros.length > 1
            ? `${nombre} — ${registros.length} servicios`
            : `Información de ${nombre}`,
        body,
        variante: "exito",
      });
      if (registros.length > 1) initAcordeon();
    }, 600);
  }

  /* ── EVENTOS ── */
  document
    .getElementById("identificacion")
    ?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") consultarEstado();
    });

  window.consultarEstado = consultarEstado;
</script>
