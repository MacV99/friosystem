<script is:inline>
  //@ts-nocheck

  const SHEET_URL =
    "https://docs.google.com/spreadsheets/d/e/2PACX-1vQW9HE0pnzSsXfqoD9qXe28EMfT2D6AFhoM3T_83Z8ajhdKDgL86tE8cSRfTTTtuVVm8j1KZLrHefc_/pub?gid=0&single=true&output=csv";

  /* ── REGISTROS ACTUALES ── */
  let _registrosActuales = [];

  /* ── TOAST ── */
  let toastTimer;
  function fsToast(msg, icono = "🔔") {
    clearTimeout(toastTimer);
    const t = document.getElementById("fs-toast");
    document.getElementById("fs-toast-icon").textContent = icono;
    document.getElementById("fs-toast-msg").textContent = msg;
    t.classList.add("fs-toast-visible");
    toastTimer = setTimeout(() => t.classList.remove("fs-toast-visible"), 3200);
  }

  /* ── MODAL ── */
  const VARIANTES = {
    aviso: { emoji: "💡", clase: "fs-icon-aviso" },
    error: { emoji: "❌", clase: "fs-icon-error" },
    exito: { emoji: "✅", clase: "fs-icon-exito" },
    carga: { emoji: "❄️", clase: "fs-icon-carga" },
  };

  function fsModalShow({ title, body, variante = "aviso" }) {
    const v = VARIANTES[variante] || VARIANTES.aviso;
    const iconEl = document.getElementById("fs-modal-icon");
    iconEl.textContent = v.emoji;
    iconEl.className = "fs-modal-icon " + v.clase;
    document.getElementById("fs-modal-title").textContent = title;
    document.getElementById("fs-modal-body").innerHTML = body;
    // Ancho amplio solo cuando hay datos de cliente (variante exito)
    document
      .querySelector(".fs-modal-card")
      .classList.toggle("fs-modal-data", variante === "exito");
    document.getElementById("fs-modal").classList.add("fs-modal-visible");
  }

  function fsModalHide() {
    document.getElementById("fs-modal").classList.remove("fs-modal-visible");
    document.getElementById("fs-modal-body").innerHTML = "";
    document.getElementById("identificacion").value = "";
  }

  document.getElementById("fs-modal-ok").onclick = fsModalHide;
  document.getElementById("fs-modal-close").onclick = fsModalHide;
  document.getElementById("fs-modal").addEventListener("click", function (e) {
    if (e.target === this) fsModalHide();
  });

  /* ── CSV PARSER (maneja campos con comas entre comillas) ── */
  function parseCsvLine(line) {
    const result = [];
    let cur = "",
      inQuote = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"') {
        inQuote = !inQuote;
      } else if (ch === "," && !inQuote) {
        result.push(cur.trim());
        cur = "";
      } else {
        cur += ch;
      }
    }
    result.push(cur.trim());
    return result;
  }

  /* ── BUSCAR COLUMNA POR PALABRAS CLAVE ── */
  function findCol(headers, ...keywords) {
    return headers.findIndex((h) => keywords.some((kw) => h.includes(kw)));
  }

  /* ── LÓGICA DE BÚSQUEDA ── */
  async function buscarDatos(identificacion, url) {
    const res = await fetch(`${url}&rand=${Date.now()}`, {
      cache: "no-store",
      mode: "cors",
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const csv = await res.text();
    const lines = csv.trim().split("\n");
    if (lines.length < 2) return null;

    const headers = parseCsvLine(lines[0]).map((h) =>
      h.toLowerCase().replace(/['"]/g, ""),
    );

    const iCedula = findCol(
      headers,
      "cedula",
      "nit",
      "identificacion",
      "cédula",
    );
    const iCliente = findCol(headers, "cliente");
    const iZona = findCol(headers, "zona");
    const iCiudad = findCol(headers, "ciudad");
    const iTipoEquipo = findCol(headers, "tipo de equipo", "tipo equipo");
    const iMarca = findCol(headers, "marca");
    const iInventario = findCol(headers, "inventario");
    const iTipoSvc = findCol(headers, "tipo servicio");
    const iCapacidad = findCol(headers, "capacidad");
    const iL1 = findCol(headers, "l1");
    const iL2 = findCol(headers, "l2");
    const iL3 = findCol(headers, "l3");
    const iSuccion = findCol(headers, "succion", "succión");
    const iDescP = findCol(headers, "p. desc");
    const iVoltaje = findCol(headers, "voltaje");
    const iTSum = findCol(headers, "t. sum");
    const iTRet = findCol(headers, "t. ret");
    const iTAmb = findCol(headers, "t. amb");
    const iDescripcion = findCol(headers, "descripcion", "descripción");
    const iMaterial = findCol(headers, "material");
    const iFuncionario = findCol(headers, "nombre funcionario");
    const iTelefono = findCol(headers, "telefono", "teléfono");
    const iFoto = findCol(headers, "fotografico", "fotográfico");
    const iCalif = findCol(headers, "calificacion", "calificación");
    const iTecnico = findCol(headers, "tecnico", "técnico");
    const iObservacion = findCol(headers, "observacion", "observación");

    if (iCedula === -1) {
      fsModalShow({
        title: "Error de configuración",
        body: `No se encontró la columna de cédula/NIT.<br><small>Columnas detectadas: ${headers.join(", ")}</small>`,
        variante: "error",
      });
      return null;
    }

    const id = identificacion.trim().toLowerCase();
    const filas = [];

    for (let i = 1; i < lines.length; i++) {
      if (!lines[i].trim()) continue;
      const cells = parseCsvLine(lines[i]);
      if (cells[iCedula]?.toLowerCase().trim() === id) {
        filas.push({
          cedula: cells[iCedula] || "",
          cliente: cells[iCliente] || "",
          zona: cells[iZona] || "",
          ciudad: cells[iCiudad] || "",
          tipoEquipo: cells[iTipoEquipo] || "",
          marca: cells[iMarca] || "",
          inventario: cells[iInventario] || "",
          tipoServicio: cells[iTipoSvc] || "",
          capacidad: cells[iCapacidad] || "",
          l1: cells[iL1] || "",
          l2: cells[iL2] || "",
          l3: cells[iL3] || "",
          succion: cells[iSuccion] || "",
          desc_p: cells[iDescP] || "",
          voltaje: cells[iVoltaje] || "",
          tSum: cells[iTSum] || "",
          tRet: cells[iTRet] || "",
          tAmb: cells[iTAmb] || "",
          descripcion: cells[iDescripcion] || "",
          material: cells[iMaterial] || "",
          funcionario: cells[iFuncionario] || "",
          telefono: cells[iTelefono] || "",
          foto: cells[iFoto] || "",
          calificacion: cells[iCalif] || "",
          tecnico: cells[iTecnico] || "",
          observacion: cells[iObservacion] || "",
        });
      }
    }

    return filas.length ? filas : null;
  }

  /* ── LISTA DE REPORTES EN MODAL ── */

  function buildReportesListHTML(registros) {
    const cards = registros
      .map((r, i) => {
        const etiqueta =
          [r.tipoEquipo, r.tipoServicio].filter(Boolean).join(" · ") ||
          `Servicio ${i + 1}`;
        return `
        <div class="reporte-card flex-row">
          <div class="reporte-card-info">
            <span class="reporte-label">Servicio ${i + 1} — ${etiqueta}</span>
            ${r.marca ? `<span class="reporte-sub">${r.marca}</span>` : ""}
          </div>
          <button class="reporte-btn flex-row" id="reporte-btn-${i}" onclick="descargarReporteHTML(${i})">
            <i class="bi bi-download"></i> Descargar
          </button>
        </div>`;
      })
      .join("");
    const n = registros.length;
    return `
      <div class="reporte-lista">
        <p class="reporte-intro">Tienes <strong>${n} reporte${n > 1 ? "s" : ""}</strong> disponible${n > 1 ? "s" : ""}:</p>
        ${cards}
      </div>`;
  }

  /* ── REPORTE: HTML → html2canvas → JPEG ── */

  function loadHtml2Canvas() {
    return new Promise((resolve, reject) => {
      if (window.html2canvas) {
        resolve(window.html2canvas);
        return;
      }
      const s = document.createElement("script");
      s.src =
        "https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js";
      s.onload = () => resolve(window.html2canvas);
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  function marcarCheckboxHTML(id, valor, etiquetas) {
    // Limpia todos primero
    etiquetas.forEach(({ elId }) => {
      const el = document.getElementById(elId);
      if (el) el.style.background = "white";
    });
    if (!valor) return;
    const norm = valor.trim().toUpperCase();
    for (const { elId, label } of etiquetas) {
      if (
        norm.includes(label.toUpperCase()) ||
        label.toUpperCase().includes(norm)
      ) {
        const el = document.getElementById(elId);
        if (el) el.style.background = "#032132";
        break;
      }
    }
  }

  function setText(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val || "—";
  }

  function descargarReporteHTML(index) {
    const d = _registrosActuales[index];
    if (!d) return;

    const btn = document.getElementById(`reporte-btn-${index}`);
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generando...';
    }

    const fecha = new Date();
    const dd = String(fecha.getDate()).padStart(2, "0");
    const mm = String(fecha.getMonth() + 1).padStart(2, "0");
    const yyyy = fecha.getFullYear();
    const fechaStr = `${dd}/${mm}/${yyyy}`;

    // Rellenar campos de texto
    setText("rh-fecha-top", fechaStr);
    setText("rh-fecha", fechaStr);
    setText("rh-cliente", (d.cliente || "").toUpperCase());
    setText("rh-cedula", d.cedula || "");
    setText("rh-zona", (d.zona || "").toUpperCase());
    setText("rh-ciudad", (d.ciudad || "").toUpperCase());
    setText("rh-marca", (d.marca || "").toUpperCase());
    setText("rh-inventario", (d.inventario || "").toUpperCase());
    setText("rh-capacidad", (d.capacidad || "").toUpperCase());
    setText("rh-l1", d.l1 || "");
    setText("rh-l2", d.l2 || "");
    setText("rh-l3", d.l3 || "");
    setText("rh-succion", d.succion || "");
    setText("rh-descp", d.desc_p || "");
    setText("rh-voltaje", d.voltaje || "");
    setText("rh-tsum", d.tSum || "");
    setText("rh-tret", d.tRet || "");
    setText("rh-tamb", d.tAmb || "");
    setText("rh-descripcion", d.descripcion || "");
    setText("rh-material", d.material || "");
    setText("rh-tecnico", (d.tecnico || "").toUpperCase());
    setText("rh-observacion", d.observacion || "");
    setText("rh-telefono", d.telefono || "");

    // Marcar checkboxes
    marcarCheckboxHTML("rh-tipo-servicio", d.tipoServicio, [
      { elId: "rh-chk-preventivo", label: "Preventivo" },
      { elId: "rh-chk-correctivo", label: "Correctivo" },
      { elId: "rh-chk-instalacion", label: "Instalacion" },
      { elId: "rh-chk-revision", label: "Revision" },
    ]);
    marcarCheckboxHTML("rh-tipo-equipo", d.tipoEquipo, [
      { elId: "rh-chk-minisplit", label: "MINI SPLIT" },
      { elId: "rh-chk-cassette", label: "CASSETTE" },
      { elId: "rh-chk-central", label: "CENTRAL" },
      { elId: "rh-chk-pisofijo", label: "PISO FIJO" },
      { elId: "rh-chk-pisofijo", label: "PISO TECHO" },
      { elId: "rh-chk-chiller", label: "CHILLER" },
      { elId: "rh-chk-nevera", label: "NEVERA" },
    ]);
    marcarCheckboxHTML("rh-calificacion", d.calificacion, [
      { elId: "rh-chk-excelente", label: "EXCELENTE" },
      { elId: "rh-chk-bueno", label: "BUENO" },
      { elId: "rh-chk-regular", label: "REGULAR" },
      { elId: "rh-chk-malo", label: "MALO" },
    ]);

    // Foto
    const fotoEl = document.getElementById("rh-foto");
    if (d.foto) {
      fotoEl.style.backgroundImage = `url('${d.foto}')`;
      fotoEl.style.backgroundSize = "cover";
      fotoEl.style.backgroundPosition = "center";
    } else {
      fotoEl.style.backgroundImage = "none";
    }

    const doCapture = () => {
      const doc = document.getElementById("reporte-html-doc");
      loadHtml2Canvas()
        .then((h2c) =>
          h2c(doc, {
            scale: 2,
            useCORS: true,
            allowTaint: false,
            backgroundColor: "#ffffff",
            logging: false,
          }),
        )
        .then((canvas) => {
          const nombre = `ReporteV2_${(d.cliente || "cliente").replace(/\s+/g, "_")}_${dd}-${mm}-${yyyy}.jpg`;
          const link = document.createElement("a");
          link.download = nombre;
          link.href = canvas.toDataURL("image/jpeg", 0.85);
          link.click();
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle"></i> Descargado';
          }
          fsToast("¡Reporte v2 descargado!", "✅");
        })
        .catch(() => {
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-download"></i> v2';
          }
          fsToast("Error al generar reporte v2", "❌");
        });
    };

    // Con background-image no hay evento onload — esperamos un tick para que el browser aplique el estilo
    if (d.foto) {
      const tempImg = new Image();
      tempImg.crossOrigin = "anonymous";
      tempImg.onload = doCapture;
      tempImg.onerror = doCapture;
      tempImg.src = d.foto;
    } else {
      doCapture();
    }
  }

  window.descargarReporteHTML = descargarReporteHTML;

  async function buscarConReintentos(identificacion, url, intentos = 3) {
    for (let i = 0; i < intentos; i++) {
      try {
        const datos = await buscarDatos(identificacion, url);
        if (datos) return datos;
      } catch (e) {
        console.warn(`Intento ${i + 1} fallido:`, e);
      }
      await new Promise((r) => setTimeout(r, 800));
    }
    return null;
  }

  async function consultarEstado() {
    const identificacion = document
      .getElementById("identificacion")
      .value.trim();

    if (!identificacion) {
      fsModalShow({
        title: "Campo vacío",
        body: "Por favor ingresa tu número de cédula o NIT para consultar.",
        variante: "aviso",
      });
      return;
    }

    fsToast("Consultando tu información...", "🔍");

    const registros = await buscarConReintentos(identificacion, SHEET_URL);

    if (!registros) {
      fsToast("No se encontró el registro", "❌");
      setTimeout(() => {
        fsModalShow({
          title: "Sin resultados",
          body: "No encontramos información asociada a esta identificación.<br>Verifica el número ingresado o contáctanos.",
          variante: "error",
        });
      }, 600);
      return;
    }

    const nombre = registros[0].cliente || identificacion;
    _registrosActuales = registros;
    const body = buildReportesListHTML(registros);

    fsToast("¡Registro encontrado!", "✅");
    setTimeout(() => {
      fsModalShow({
        title:
          registros.length > 1
            ? `${nombre} — ${registros.length} reportes disponibles`
            : `Reporte disponible — ${nombre}`,
        body,
        variante: "exito",
      });
    }, 600);
  }

  /* ── EVENTOS ── */
  document
    .getElementById("identificacion")
    ?.addEventListener("keypress", (e) => {
      if (e.key === "Enter") consultarEstado();
    });

  window.consultarEstado = consultarEstado;
</script>
