<section id="reporte-mantenimiento" class="flex-column">

  <!-- ── PANTALLA DE ACCESO ── -->
  <div id="acceso-card" class="acceso-card flex-column">
    <div class="acceso-icon">
      <i class="bi bi-shield-lock"></i>
    </div>
    <h2>Acceso Restringido</h2>
    <p>Esta sección es exclusiva para técnicos de AC FrioSystem.<br/>Ingresa la contraseña para continuar.</p>
    <div class="acceso-input-wrap">
      <input
        type="password"
        id="acceso-password"
        placeholder="Contraseña"
        onkeydown="if(event.key==='Enter') verificarAcceso()"
        autocomplete="current-password"
      />
      <button onclick="verificarAcceso()" class="flex-row">
        <i class="bi bi-unlock"></i> Ingresar
      </button>
    </div>
    <p id="acceso-error" class="acceso-error flex-row" style="display:none;">
      <i class="bi bi-x-circle"></i> Contraseña incorrecta
    </p>
  </div>

  <div id="formulario-reporte" style="display:none;width:100%;">
  <div class="form-card flex-column">
    <div class="form-header">
      <div class="form-header-icon flex-row">
        <i class="bi bi-file-earmark-text"></i>
      </div>
      <div>
        <h2>Reporte de Mantenimiento</h2>
        <p class="form-subtitle">
          Complete los campos y genere el reporte en imagen
        </p>
      </div>
    </div>

    <div class="divider"></div>

    <div class="form-group">
      <label for="cliente">
        <i class="bi bi-person"></i>
        Cliente
      </label>
      <input
        type="text"
        id="cliente"
        placeholder="Nombre completo del cliente"
      />
    </div>

    <div class="form-group">
      <label for="marca">
        <i class="bi bi-wind"></i>
        Marca Equipo #1
      </label>
      <input type="text" id="marca" placeholder="Ej: LG, Samsung, Carrier..." />
    </div>

    <div class="form-group">
      <label for="tecnico">
        <i class="bi bi-person-badge"></i>
        Técnico
      </label>
      <input
        type="text"
        id="tecnico"
        placeholder="Nombre del técnico responsable"
      />
    </div>

    <button onclick="generarReporte()" class="btn-generar flex-row" id="btn-generar">
      <i class="bi bi-download" id="btn-icon"></i>
      <span id="btn-texto">Generar Reporte</span>
    </button>

    <p class="form-note flex-row">
      <i class="bi bi-info-circle"></i>
      Si los campos están vacíos se usarán valores de prueba
    </p>
  </div>

  <canvas id="reporteCanvas" width="1754" height="2481" style="display:none;"
  ></canvas>

  <!-- ── MODAL ── -->
  <div id="fsr-modal" class="fsr-modal-backdrop flex-row">
    <div class="fsr-modal-card">
      <button id="fsr-modal-close" class="fsr-modal-close flex-row" aria-label="Cerrar">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="fsr-modal-icon-wrap flex-row">
        <div id="fsr-modal-icon" class="fsr-modal-icon flex-row"></div>
      </div>

      <div class="fsr-modal-header flex-row">
        <span id="fsr-modal-title">Aviso</span>
      </div>

      <div id="fsr-modal-body" class="fsr-modal-body"></div>

      <div class="fsr-modal-footer flex-row">
        <button id="fsr-modal-ok" class="fsr-modal-btn">Entendido</button>
      </div>
    </div>
  </div>

  <!-- ── TOAST ── -->
  <div id="fsr-toast" class="fsr-toast flex-row">
    <span id="fsr-toast-icon" class="fsr-toast-icon"></span>
    <span id="fsr-toast-msg"></span>
  </div>
  </div> <!-- /formulario-reporte -->
</section>

<style>
