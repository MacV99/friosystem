</style>

<script>
  // @ts-nocheck

  /* ── CONTROL DE ACCESO ── */
  function verificarAcceso() {
    const input = document.getElementById("acceso-password");
    const error = document.getElementById("acceso-error");
    if (input.value === "FrioSystem123") {
      document.getElementById("acceso-card").style.display = "none";
      document.getElementById("formulario-reporte").style.display = "block";
    } else {
      error.style.display = "flex";
      input.value = "";
      input.focus();
      setTimeout(() => (error.style.display = "none"), 3000);
    }
  }

  const VALORES_PRUEBA = {
    cliente: "JUAN PEREZ GOMEZ",
    marca: "LG",
    tecnico: "CARLOS RODRIGUEZ",
  };

  /* ── TOAST ── */
  let fsrToastTimer;
  function fsrToast(msg, icono = "🔔") {
    clearTimeout(fsrToastTimer);
    const t = document.getElementById("fsr-toast");
    document.getElementById("fsr-toast-icon").textContent = icono;
    document.getElementById("fsr-toast-msg").textContent = msg;
    t.classList.add("fsr-toast-visible");
    fsrToastTimer = setTimeout(
      () => t.classList.remove("fsr-toast-visible"),
      3200,
    );
  }

  /* ── MODAL ── */
  const FSR_VARIANTES = {
    aviso: { emoji: "💡", clase: "fsr-icon-aviso" },
    error: { emoji: "❌", clase: "fsr-icon-error" },
    exito: { emoji: "✅", clase: "fsr-icon-exito" },
  };

  function fsrModalShow({ title, body, variante = "aviso" }) {
    const v = FSR_VARIANTES[variante] || FSR_VARIANTES.aviso;
    const iconEl = document.getElementById("fsr-modal-icon");
    iconEl.textContent = v.emoji;
    iconEl.className = "fsr-modal-icon " + v.clase;
    document.getElementById("fsr-modal-title").textContent = title;
    document.getElementById("fsr-modal-body").innerHTML = body;
    document.getElementById("fsr-modal").classList.add("fsr-modal-visible");
  }

  function fsrModalHide() {
    document.getElementById("fsr-modal").classList.remove("fsr-modal-visible");
  }

  document.getElementById("fsr-modal-ok").onclick = fsrModalHide;
  document.getElementById("fsr-modal-close").onclick = fsrModalHide;
  document.getElementById("fsr-modal").addEventListener("click", function (e) {
    if (e.target === this) fsrModalHide();
  });

  /* ── BOTÓN: estados visuales ── */
  function setBtnEstado(estado) {
    const btn = document.getElementById("btn-generar");
    const icono = document.getElementById("btn-icon");
    const texto = document.getElementById("btn-texto");

    const estados = {
      normal: { icon: "bi-download", txt: "Generar Reporte", disabled: false },
      cargando: {
        icon: "bi-hourglass-split",
        txt: "Generando...",
        disabled: true,
      },
      exito: {
        icon: "bi-check-circle",
        txt: "¡Reporte listo!",
        disabled: true,
      },
    };

    const e = estados[estado] || estados.normal;
    icono.className = `bi ${e.icon}`;
    texto.textContent = e.txt;
    btn.disabled = e.disabled;
  }

  /* ── GENERAR REPORTE ── */
  function generarReporte() {
    const cliente =
      document.getElementById("cliente").value || VALORES_PRUEBA.cliente;
    const marca =
      document.getElementById("marca").value || VALORES_PRUEBA.marca;
    const tecnico =
      document.getElementById("tecnico").value || VALORES_PRUEBA.tecnico;

    const canvas = document.getElementById("reporteCanvas");
    const ctx = canvas.getContext("2d");

    setBtnEstado("cargando");
    fsrToast("Generando reporte...", "⏳");

    const plantilla = new Image();
    plantilla.crossOrigin = "anonymous";
    plantilla.src = "/img/reporte/reporte.jpg";

    plantilla.onload = function () {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.drawImage(plantilla, 0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "#000000";
      ctx.font = "24px Montserrat, Arial";
      ctx.textAlign = "left";

      ctx.fillText(cliente.toUpperCase(), 232, 430);
      ctx.fillText(marca.toUpperCase(), 310, 535);
      ctx.fillText(tecnico.toUpperCase(), 1105, 2150);

      const fecha = new Date();
      const link = document.createElement("a");
      const nombre = `Reporte_${cliente.replace(/\s+/g, "_")}_${fecha.getDate()}-${fecha.getMonth() + 1}-${fecha.getFullYear()}.jpg`;

      link.download = nombre;
      link.href = canvas.toDataURL("image/jpeg", 1.0);
      link.click();

      setBtnEstado("exito");
      fsrToast("¡Reporte descargado!", "✅");

      setTimeout(() => {
        fsrModalShow({
          title: "Reporte generado",
          body: `El reporte de <strong>${cliente}</strong> fue generado correctamente.<br><small style="color:#888">Archivo: ${nombre}</small>`,
          variante: "exito",
        });
        setBtnEstado("normal");
      }, 800);
    };

    plantilla.onerror = function () {
      setBtnEstado("normal");
      fsrToast("Error al cargar la plantilla", "❌");
      setTimeout(() => {
        fsrModalShow({
          title: "Error de plantilla",
          body: "No se pudo cargar la imagen base del reporte.<br><small>Verifica que el archivo exista en: <code>/img/reporte/plantilla_reporte.jpg</code></small>",
          variante: "error",
        });
      }, 400);
    };
  }

  window.generarReporte = generarReporte;
  window.verificarAcceso = verificarAcceso;
</script>
